<%- include('layout-header') %>

<div class="mb-8 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <div>
        <h1 class="text-3xl font-bold text-slate-900 tracking-tight">Kontrol Paneli</h1>
        <p class="text-slate-500 mt-1 font-medium">Sitenizin performansını ve içeriklerini buradan izleyebilirsiniz.</p>
    </div>
    <div class="flex items-center space-x-3 text-sm">
        <span class="px-3 py-1.5 bg-white border border-slate-200 rounded-lg text-slate-600 font-medium">
            <i class="far fa-calendar-alt mr-2"></i>
            <%= new Date().toLocaleDateString('tr-TR') %>
        </span>
    </div>
</div>

<!-- Stats Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
    <div class="bg-white p-6 rounded-3xl shadow-sm border border-slate-100 relative overflow-hidden group">
        <div class="absolute -right-4 -bottom-4 w-24 h-24 bg-cold-blue/5 rounded-full group-hover:scale-110 transition-transform duration-500"></div>
        <div class="relative z-10 flex items-center space-x-4">
            <div class="w-12 h-12 bg-cold-blue/10 rounded-2xl flex items-center justify-center text-cold-blue">
                <i class="fas fa-envelope text-xl"></i>
            </div>
            <div>
                <p class="text-sm text-slate-500 font-bold uppercase tracking-wider">Yeni Mesajlar</p>
                <h3 class="text-3xl font-black text-slate-900 mt-1"><%= messageCount %></h3>
            </div>
        </div>
    </div>
    
    <div class="bg-white p-6 rounded-3xl shadow-sm border border-slate-100 relative overflow-hidden group">
        <div class="absolute -right-4 -bottom-4 w-24 h-24 bg-emerald-50 rounded-full group-hover:scale-110 transition-transform duration-500"></div>
        <div class="relative z-10 flex items-center space-x-4">
            <div class="w-12 h-12 bg-emerald-50 rounded-2xl flex items-center justify-center text-emerald-600">
                <i class="fas fa-inbox text-xl"></i>
            </div>
            <div>
                <p class="text-sm text-slate-500 font-bold uppercase tracking-wider">Toplam Mesaj</p>
                <h3 class="text-3xl font-black text-slate-900 mt-1"><%= totalMessages %></h3>
            </div>
        </div>
    </div>

    <div class="bg-white p-6 rounded-3xl shadow-sm border border-slate-100 relative overflow-hidden group">
        <div class="absolute -right-4 -bottom-4 w-24 h-24 bg-amber-50 rounded-full group-hover:scale-110 transition-transform duration-500"></div>
        <div class="relative z-10 flex items-center space-x-4">
            <div class="w-12 h-12 bg-amber-50 rounded-2xl flex items-center justify-center text-amber-600">
                <i class="fas fa-briefcase text-xl"></i>
            </div>
            <div>
                <p class="text-sm text-slate-500 font-bold uppercase tracking-wider">Hizmet Sayısı</p>
                <h3 class="text-3xl font-black text-slate-900 mt-1">3</h3>
            </div>
        </div>
    </div>

    <div class="bg-white p-6 rounded-3xl shadow-sm border border-slate-100 relative overflow-hidden group">
        <div class="absolute -right-4 -bottom-4 w-24 h-24 bg-purple-50 rounded-full group-hover:scale-110 transition-transform duration-500"></div>
        <div class="relative z-10 flex items-center space-x-4">
            <div class="w-12 h-12 bg-purple-50 rounded-2xl flex items-center justify-center text-purple-600">
                <i class="fas fa-shield-alt text-xl"></i>
            </div>
            <div>
                <p class="text-sm text-slate-500 font-bold uppercase tracking-wider">Yöneticiler</p>
                <h3 class="text-3xl font-black text-slate-900 mt-1">1</h3>
            </div>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Quick Actions -->
    <div class="lg:col-span-2 space-y-8">
        <div class="bg-white p-8 rounded-3xl shadow-sm border border-slate-100">
            <div class="flex items-center justify-between mb-8">
                <h2 class="text-xl font-bold text-slate-900">Hızlı İşlemler</h2>
                <i class="fas fa-bolt text-amber-400"></i>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <a href="/admin/content" class="p-6 bg-slate-50 rounded-2xl hover:bg-cold-blue hover:text-white transition-all group flex flex-col items-center text-center">
                    <div class="w-14 h-14 bg-white rounded-xl shadow-sm flex items-center justify-center mb-4 group-hover:bg-white/20 transition-colors">
                        <i class="fas fa-edit text-2xl text-cold-blue group-hover:text-white"></i>
                    </div>
                    <span class="font-bold text-lg">İçerik Düzenle</span>
                    <p class="text-xs mt-2 text-slate-400 group-hover:text-white/70">Metinler, görseller ve SEO ayarları</p>
                </a>
                <a href="/admin/messages" class="p-6 bg-slate-50 rounded-2xl hover:bg-cold-blue hover:text-white transition-all group flex flex-col items-center text-center">
                    <div class="w-14 h-14 bg-white rounded-xl shadow-sm flex items-center justify-center mb-4 group-hover:bg-white/20 transition-colors">
                        <i class="fas fa-comment-dots text-2xl text-cold-blue group-hover:text-white"></i>
                    </div>
                    <span class="font-bold text-lg">Mesajları Oku</span>
                    <p class="text-xs mt-2 text-slate-400 group-hover:text-white/70">Müşterilerden gelen son talepler</p>
                </a>
            </div>
        </div>
    </div>
    
    <!-- System Info -->
    <div class="space-y-8">
        <div class="bg-white p-8 rounded-3xl shadow-sm border border-slate-100">
            <div class="flex items-center justify-between mb-8">
                <h2 class="text-xl font-bold text-slate-900">Sistem Durumu</h2>
                <div class="w-3 h-3 bg-emerald-500 rounded-full animate-ping"></div>
            </div>
            <ul class="space-y-6">
                <li class="flex items-center justify-between">
                    <div class="flex items-center space-x-3">
                        <div class="w-8 h-8 bg-slate-100 rounded-lg flex items-center justify-center">
                            <i class="fab fa-node-js text-emerald-600"></i>
                        </div>
                        <span class="text-sm font-medium text-slate-600">Node.js</span>
                    </div>
                    <span class="text-xs font-mono bg-slate-50 px-2 py-1 rounded text-slate-500"><%= process.version %></span>
                </li>
                <li class="flex items-center justify-between">
                    <div class="flex items-center space-x-3">
                        <div class="w-8 h-8 bg-slate-100 rounded-lg flex items-center justify-center">
                            <i class="fas fa-microchip text-blue-600"></i>
                        </div>
                        <span class="text-sm font-medium text-slate-600">Platform</span>
                    </div>
                    <span class="text-xs font-mono bg-slate-50 px-2 py-1 rounded text-slate-500 capitalize"><%= process.platform %></span>
                </li>
                <li class="flex items-center justify-between">
                    <div class="flex items-center space-x-3">
                        <div class="w-8 h-8 bg-slate-100 rounded-lg flex items-center justify-center">
                            <i class="fas fa-server text-purple-600"></i>
                        </div>
                        <span class="text-sm font-medium text-slate-600">Durum</span>
                    </div>
                    <span class="text-xs font-bold text-emerald-500">Çalışıyor</span>
                </li>
            </ul>
            <div class="mt-8 pt-8 border-t border-slate-50">
                <a href="/admin/profile" class="w-full py-3 bg-slate-900 text-white rounded-xl font-bold text-sm flex items-center justify-center space-x-2 hover:bg-slate-800 transition-all">
                    <i class="fas fa-cog"></i>
                    <span>Sistem Ayarları</span>
                </a>
            </div>
        </div>
    </div>
</div>

<%- include('layout-footer') %>
