<%- include('layout-header') %>

<div class="mb-8">
    <h1 class="text-3xl font-bold text-slate-900">Admin Profili</h1>
    <p class="text-slate-500 mt-2">Yönetim paneli giriş bilgilerini buradan güncelleyebilirsiniz.</p>
</div>

<div class="max-w-2xl">
    <% if (success) { %>
        <div class="mb-6 p-4 bg-emerald-50 border border-emerald-100 text-emerald-600 rounded-2xl flex items-center space-x-3">
            <i class="fas fa-check-circle"></i>
            <span class="font-medium"><%= success %></span>
        </div>
    <% } %>

    <% if (error) { %>
        <div class="mb-6 p-4 bg-red-50 border border-red-100 text-red-600 rounded-2xl flex items-center space-x-3">
            <i class="fas fa-exclamation-circle"></i>
            <span class="font-medium"><%= error %></span>
        </div>
    <% } %>

    <div class="bg-white p-8 rounded-3xl shadow-sm border border-slate-100">
        <form action="/admin/profile" method="POST" class="space-y-6">
            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">Kullanıcı Adı</label>
                <div class="relative">
                    <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-slate-400">
                        <i class="fas fa-user"></i>
                    </span>
                    <input type="text" name="username" value="<%= admin.username %>" required class="w-full pl-11 pr-4 py-3.5 rounded-xl border border-slate-200 focus:ring-2 focus:ring-cold-blue focus:border-cold-blue outline-none transition-all">
                </div>
            </div>

            <div class="pt-4 border-t border-slate-50">
                <h3 class="text-lg font-bold text-slate-800 mb-4">Şifre Değiştir</h3>
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-2">Mevcut Şifre</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-slate-400">
                                <i class="fas fa-lock"></i>
                            </span>
                            <input type="password" name="password" required class="w-full pl-11 pr-4 py-3.5 rounded-xl border border-slate-200 focus:ring-2 focus:ring-cold-blue focus:border-cold-blue outline-none transition-all" placeholder="Değişiklik için mevcut şifrenizi girin">
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-2">Yeni Şifre (İsteğe bağlı)</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-slate-400">
                                <i class="fas fa-key"></i>
                            </span>
                            <input type="password" name="new_password" class="w-full pl-11 pr-4 py-3.5 rounded-xl border border-slate-200 focus:ring-2 focus:ring-cold-blue focus:border-cold-blue outline-none transition-all" placeholder="Yeni şifre belirlemek istemiyorsanız boş bırakın">
                        </div>
                    </div>
                </div>
            </div>

            <div class="pt-6">
                <button type="submit" class="w-full bg-cold-blue hover:bg-deep-blue text-white font-bold py-4 rounded-xl transition-all shadow-lg shadow-cold-blue/20 flex items-center justify-center space-x-2">
                    <i class="fas fa-save"></i>
                    <span>Değişiklikleri Kaydet</span>
                </button>
            </div>
        </form>
    </div>
</div>

<%- include('layout-footer') %>
