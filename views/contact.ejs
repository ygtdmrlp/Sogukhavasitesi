<%- include('partials/header') %>

<!-- Page Header -->
<section class="bg-deep-blue text-white py-20">
    <div class="container mx-auto px-4 text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">İletişim</h1>
        <p class="text-xl text-slate-300">Bize her türlü sorunuz için ulaşabilirsiniz.</p>
    </div>
</section>

<!-- Contact Info & Form -->
<section class="py-24 bg-white">
    <div class="container mx-auto px-4">
        <div class="flex flex-col lg:flex-row gap-16">
            <!-- Info -->
            <div class="lg:w-1/3">
                <h2 class="text-3xl font-bold text-deep-blue mb-8">Bize Ulaşın</h2>
                <div class="space-y-8">
                    <div class="flex items-start space-x-4">
                        <div class="w-12 h-12 bg-ice-blue rounded-xl flex items-center justify-center text-cold-blue flex-shrink-0">
                            <i class="fas fa-location-dot text-xl"></i>
                        </div>
                        <div>
                            <h4 class="font-bold text-deep-blue mb-1">Adres</h4>
                            <p class="text-cold-gray"><%= site.address %></p>
                        </div>
                    </div>
                    <div class="flex items-start space-x-4">
                        <div class="w-12 h-12 bg-ice-blue rounded-xl flex items-center justify-center text-cold-blue flex-shrink-0">
                            <i class="fas fa-phone text-xl"></i>
                        </div>
                        <div>
                            <h4 class="font-bold text-deep-blue mb-1">Telefon</h4>
                            <p class="text-cold-gray"><%= site.phone %></p>
                        </div>
                    </div>
                    <div class="flex items-start space-x-4">
                        <div class="w-12 h-12 bg-ice-blue rounded-xl flex items-center justify-center text-cold-blue flex-shrink-0">
                            <i class="fas fa-envelope text-xl"></i>
                        </div>
                        <div>
                            <h4 class="font-bold text-deep-blue mb-1">E-mail</h4>
                            <p class="text-cold-gray"><%= site.email %></p>
                        </div>
                    </div>
                </div>

                <!-- Map -->
                <div class="mt-12 rounded-2xl overflow-hidden shadow-lg h-64 border-4 border-ice-blue">
                    <iframe 
                        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3008.349637775532!2d28.790675276536033!3d41.07231451554625!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14caa569265f2127%3A0x6b6d51a6628c686e!2zSXBva2Fzw7xrIE9yZ2FuaXplIFNhbmF5aSBCw7ZsZ2VzaQ!5e0!3m2!1str!2str!4v1710595000000!5m2!1str!2str" 
                        width="100%" 
                        height="100%" 
                        style="border:0;" 
                        allowfullscreen="" 
                        loading="lazy" 
                        referrerpolicy="no-referrer-when-downgrade">
                    </iframe>
                </div>
            </div>

            <!-- Form -->
            <div class="lg:w-2/3">
                <div class="bg-ice-blue/50 p-8 md:p-12 rounded-3xl border border-ice-blue shadow-sm">
                    <h3 class="text-2xl font-bold text-deep-blue mb-8">Hızlı Teklif Formu</h3>
                    <form id="contactForm" class="space-y-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-sm font-bold text-deep-blue mb-2" for="name">Adınız Soyadınız</label>
                                <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-cold-blue focus:border-transparent transition-all">
                            </div>
                            <div>
                                <label class="block text-sm font-bold text-deep-blue mb-2" for="phone">Telefon Numaranız</label>
                                <input type="tel" id="phone" name="phone" required class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-cold-blue focus:border-transparent transition-all" placeholder="05xx xxx xx xx">
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-bold text-deep-blue mb-2" for="email">E-mail Adresiniz</label>
                            <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-cold-blue focus:border-transparent transition-all">
                        </div>
                        <div>
                            <label class="block text-sm font-bold text-deep-blue mb-2" for="message">Mesajınız</label>
                            <textarea id="message" name="message" rows="6" required class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-cold-blue focus:border-transparent transition-all"></textarea>
                        </div>
                        <button type="submit" class="btn-primary w-full md:w-auto py-4 px-12">Mesajı Gönder</button>
                        <div id="formResponse" class="hidden mt-6 p-4 rounded-xl text-center font-bold"></div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    document.getElementById('contactForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const responseDiv = document.getElementById('formResponse');
        const submitBtn = e.target.querySelector('button');
        
        submitBtn.disabled = true;
        submitBtn.innerText = 'Gönderiliyor...';
        
        const nameField = document.getElementById('name');
        const phoneField = document.getElementById('phone');
        const emailField = document.getElementById('email');
        const messageField = document.getElementById('message');

        if (!nameField || !phoneField || !emailField || !messageField) {
            console.error('One or more form fields not found!');
            submitBtn.disabled = false;
            submitBtn.innerText = 'Mesajı Gönder';
            return;
        }

        const formData = {
            name: nameField.value,
            phone: phoneField.value,
            email: emailField.value,
            message: messageField.value
        };

        if (!formData.phone) {
            responseDiv.classList.remove('hidden', 'bg-green-100', 'text-green-700');
            responseDiv.classList.add('bg-red-100', 'text-red-700');
            responseDiv.innerText = 'Lütfen telefon numaranızı giriniz.';
            submitBtn.disabled = false;
            submitBtn.innerText = 'Mesajı Gönder';
            return;
        }

        try {
            const response = await fetch('/iletisim', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(formData)
            });
            const data = await response.json();
            
            responseDiv.classList.remove('hidden', 'bg-red-100', 'text-red-700', 'bg-green-100', 'text-green-700');
            if (data.success) {
                responseDiv.classList.add('bg-green-100', 'text-green-700');
                responseDiv.innerText = data.message;
                e.target.reset();
            } else {
                responseDiv.classList.add('bg-red-100', 'text-red-700');
                responseDiv.innerText = data.message;
            }
        } catch (error) {
            responseDiv.classList.remove('hidden');
            responseDiv.classList.add('bg-red-100', 'text-red-700');
            responseDiv.innerText = 'Bir hata oluştu. Lütfen tekrar deneyin.';
        } finally {
            submitBtn.disabled = false;
            submitBtn.innerText = 'Mesajı Gönder';
        }
    });
</script>

<%- include('partials/footer') %>
