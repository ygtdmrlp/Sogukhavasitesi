    <!-- Footer -->
    <footer class="bg-deep-blue text-white pt-16 pb-8">
        <div class="container mx-auto px-4 grid grid-cols-1 md:grid-cols-4 gap-12 border-b border-white/10 pb-12 mb-8">
            <!-- Brand -->
            <div class="col-span-1 md:col-span-1">
                <a href="/" class="flex items-center space-x-2 mb-6">
                    <% if (site.logo) { %>
                        <img src="<%= site.logo %>" alt="<%= site.title %> Logo" class="h-12 w-auto">
                    <% } else { %>
                        <i class="fas fa-snowflake text-ice-blue text-3xl"></i>
                        <span class="text-2xl font-bold tracking-tight text-ice-blue"><%= site.title %></span>
                    <% } %>
                </a>
                <p class="text-white/70 leading-relaxed mb-6">
                    <%= site.footer && site.footer.about_text ? site.footer.about_text : site.description %>
                </p>
                <div class="flex space-x-4">
                    <% if (site.social && site.social.facebook) { %>
                        <a href="<%= site.social.facebook %>" target="_blank" class="text-white/70 hover:text-white transition-colors"><i class="fab fa-facebook-f text-xl"></i></a>
                    <% } %>
                    <% if (site.social && site.social.instagram) { %>
                        <a href="<%= site.social.instagram %>" target="_blank" class="text-white/70 hover:text-white transition-colors"><i class="fab fa-instagram text-xl"></i></a>
                    <% } %>
                    <% if (site.social && site.social.twitter) { %>
                        <a href="<%= site.social.twitter %>" target="_blank" class="text-white/70 hover:text-white transition-colors"><i class="fab fa-twitter text-xl"></i></a>
                    <% } %>
                    <% if (site.social && site.social.linkedin) { %>
                        <a href="<%= site.social.linkedin %>" target="_blank" class="text-white/70 hover:text-white transition-colors"><i class="fab fa-linkedin-in text-xl"></i></a>
                    <% } %>
                </div>
            </div>

            <!-- Services -->
            <div class="col-span-1">
                <h4 class="text-xl font-bold mb-6 border-b border-white/20 pb-2">Hizmetlerimiz</h4>
                <ul class="space-y-3 text-white/70">
                    <% services.forEach(service => { %>
                        <li><a href="/hizmetler" class="hover:text-ice-blue transition-colors"><%= service.title %></a></li>
                    <% }) %>
                </ul>
            </div>

            <!-- Quick Links -->
            <div class="col-span-1">
                <h4 class="text-xl font-bold mb-6 border-b border-white/20 pb-2">Hızlı Menü</h4>
                <ul class="space-y-3 text-white/70">
                    <li><a href="/" class="hover:text-ice-blue transition-colors">Ana Sayfa</a></li>
                    <li><a href="/hakkimizda" class="hover:text-ice-blue transition-colors">Hakkımızda</a></li>
                    <li><a href="/projeler" class="hover:text-ice-blue transition-colors">Projeler</a></li>
                    <li><a href="/iletisim" class="hover:text-ice-blue transition-colors">İletişim</a></li>
                </ul>
            </div>

            <!-- Contact -->
            <div class="col-span-1">
                <h4 class="text-xl font-bold mb-6 border-b border-white/20 pb-2">Bize Ulaşın</h4>
                <ul class="space-y-4 text-white/70">
                    <li class="flex items-start space-x-3">
                        <i class="fas fa-location-dot mt-1 text-cold-blue"></i>
                        <span><%= site.address %></span>
                    </li>
                    <li class="flex items-center space-x-3">
                        <i class="fas fa-phone text-cold-blue"></i>
                        <span><%= site.phone %></span>
                    </li>
                    <li class="flex items-center space-x-3">
                        <i class="fas fa-envelope text-cold-blue"></i>
                        <span><%= site.email %></span>
                    </li>
                </ul>
            </div>
        </div>

        <div class="container mx-auto px-4 text-center text-white/40 text-sm">
            <%= site.footer && site.footer.copyright ? site.footer.copyright : '© 2026 ' + site.title + '. Tüm hakları saklıdır.' %>
        </div>
    </footer>
</body>
</html>
