<%- include('partials/header') %>

<!-- Page Header -->
<section class="bg-deep-blue text-white py-20">
    <div class="container mx-auto px-4 text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4"><%= services_page.title %></h1>
        <p class="text-xl text-slate-300"><%= services_page.subtitle %></p>
    </div>
</section>

<!-- Services Detail List -->
<section class="py-24 bg-white">
    <div class="container mx-auto px-4 space-y-24">
        <% services.forEach((service, index) => { %>
            <!-- Service Item -->
            <div class="flex flex-col <%= index % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse' %> items-center gap-12">
                <div class="md:w-1/2">
                    <img src="<%= service.image %>" 
                         alt="<%= service.title %>" 
                         class="rounded-3xl shadow-2xl w-full h-[400px] object-cover">
                </div>
                <div class="md:w-1/2">
                    <span class="text-cold-blue font-bold uppercase tracking-widest text-sm"><%= service.tag %></span>
                    <h2 class="text-4xl font-bold text-deep-blue mt-2 mb-6 leading-tight"><%= service.title %></h2>
                    <p class="text-cold-gray text-lg leading-relaxed mb-8">
                        <%= service.description %>
                    </p>
                    <ul class="space-y-4 mb-10">
                        <% if (service.features && Array.isArray(service.features)) { %>
                            <% service.features.forEach(feature => { %>
                                <li class="flex items-center space-x-3 text-deep-blue font-medium">
                                    <i class="fas fa-check-circle text-cold-blue"></i>
                                    <span><%= feature %></span>
                                </li>
                            <% }) %>
                        <% } else { %>
                            <li class="flex items-center space-x-3 text-deep-blue font-medium">
                                <i class="fas fa-check-circle text-cold-blue"></i>
                                <span>Yüksek Kaliteli Malzeme</span>
                            </li>
                            <li class="flex items-center space-x-3 text-deep-blue font-medium">
                                <i class="fas fa-check-circle text-cold-blue"></i>
                                <span>Enerji Verimli Sistemler</span>
                            </li>
                            <li class="flex items-center space-x-3 text-deep-blue font-medium">
                                <i class="fas fa-check-circle text-cold-blue"></i>
                                <span>7/24 Teknik Destek</span>
                            </li>
                        <% } %>
                    </ul>
                    <a href="/iletisim" class="btn-primary inline-block">Bilgi ve Teklif Al</a>
                </div>
            </div>
        <% }) %>
    </div>
</section>

<%- include('partials/footer') %>
